. . . . . . . . . . . \n        . . . . . . . . . . . . . . . . \n        . . . . . . 2 2 2 . . . . . . . \n        . . . . . . 2 2 2 . . . . . . . \n        . . . . . . 2 2 2 . . . . . . . \n        . . . . . . . . . . . . . . . . \n        . . . . . . . . . . . . . . . . \n        . . . . . . . . . . . . . . . . \n        . . . . . . . . . . . . . . . . \n        . . . . . . . . . . . . . . . . \n        . . . . . . . . . . . . . . . . \n        `, SpriteKind.pointsquare)\n        point.x = sprite3.x + x\n        point.y = sprite3.y - y\n        sprites.setDataBoolean(point, \"can capture\", bool)\n        sprites.setDataBoolean(point, \"can move\", bool2)\n    }\n\n    // --- FUNCTION 3 ---\n    //% block=\"shake camera for $duration ms\"\n    export function shakeCamera(duration: number) {\n        scene.cameraShake(4, duration)\n    }\n}\n"}]},{"timestamp":1782076986298,"editorVersion":"4.0.14","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":72,"length1":98,"diffs":[[1,"        \"device\": \"*\"\n"]]}]}]},{"timestamp":1782077580452,"editorVersion":"4.0.14","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":95,"length1":150,"diffs":[[1,"        \"arcade-sprite-data\": \"github:microsoft/arcade-sprite-data#v0.2.1\"\n"]]}]},{"type":"edited","filename":"custom.ts","patch":[{"start1":910,"length1":76,"diffs":[[1,"    //% block=\"reset game score\"\n"]]},{"start1":1748,"length1":25,"diffs":[[1,"        `, SpriteKind.pointsquare)\n"]]}]}]},{"timestamp":1782078131073,"editorVersion":"4.0.14","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":157,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":380,"length1":44,"diffs":[[1,""]]}]},{"type":"added","filename":"test.ts","value":"// tests go here; this will not be compiled when this packa